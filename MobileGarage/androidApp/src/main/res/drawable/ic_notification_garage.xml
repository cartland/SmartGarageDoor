<!--
  Status-bar notification icon for garage door alerts (the open-door warning
  and its resolution). Status-bar small icons are tinted by the system using
  only the alpha channel, so this is a white-on-transparent silhouette: a
  peaked garage front with three door slats carved out via evenOdd holes.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="#FFFFFFFF">
  <path
      android:fillColor="#FFFFFFFF"
      android:fillType="evenOdd"
      android:pathData="M12,3.2 L3,9.2 L3,21 L21,21 L21,9.2 Z M6.5,13 L17.5,13 L17.5,14.3 L6.5,14.3 Z M6.5,15.7 L17.5,15.7 L17.5,17 L6.5,17 Z M6.5,18.4 L17.5,18.4 L17.5,19.7 L6.5,19.7 Z" />
</vector>
