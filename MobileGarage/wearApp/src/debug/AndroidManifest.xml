<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- Debug-only fixture screen for capturing store-listing screenshots
             on a Wear emulator. Renders HeroScreenContent with canned states;
             no ViewModel, no network, no auth. Launched via adb:
             am start -n <appId>/com.chriscartland.garage.wear.debug.ScreenshotStagesActivity \
               -e stage closed|armed|moving|open -->
        <activity
            android:name="com.chriscartland.garage.wear.debug.ScreenshotStagesActivity"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault" />
    </application>

</manifest>
