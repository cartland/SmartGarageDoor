# The Xcode project is generated from project.yml by XcodeGen — never commit it.
*.xcodeproj/

# Local secret overlay (real GARAGE_SERVER_CONFIG_KEY). Mirrors gitignored
# local.properties on Android. The committed Secrets.xcconfig #include?s it.
Secrets.local.xcconfig

# Build output
build/
DerivedData/

# Snapshot gallery (scripts/generate-ios-screenshots.sh).
#   - The recorded reference PNGs under SnapshotTests/__Snapshots__/ and the
#     generated SCREENSHOT_GALLERY.md ARE committed — they are the browsable
#     visual reference.
#   - PreviewTests.generated.swift is NOT committed: it is fully derived from the
#     #Preview macros + .prefire.yml, regenerated by the script before every run.
#   - .derivedData-snapshots/ is the script's private DerivedData.
.derivedData-snapshots/
SnapshotTests/PreviewTests.generated.swift

# Xcode user state
*.xcuserstate
**/xcuserdata/

.DS_Store
