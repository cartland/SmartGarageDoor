# The Xcode project is generated from project.yml by XcodeGen — never commit it.
*.xcodeproj/

# Local secret overlay (real GARAGE_SERVER_CONFIG_KEY). Mirrors gitignored
# local.properties on Android. The committed Secrets.xcconfig #include?s it.
Secrets.local.xcconfig

# Build output
build/
DerivedData/

# Snapshot-generation DerivedData (scripts/generate-ios-screenshots.sh). The
# recorded reference PNGs under SnapshotTests/__Snapshots__/ and the generated
# SnapshotTests/PreviewTests.generated.swift ARE committed (they are the gallery).
.derivedData-snapshots/

# Xcode user state
*.xcuserstate
**/xcuserdata/

.DS_Store
