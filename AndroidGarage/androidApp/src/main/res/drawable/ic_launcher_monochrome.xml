<!--
  Monochrome layer for Android 13+ themed icons. A single-color garage-door
  silhouette: the door is filled, with the window row and slat gaps cut out
  (fillType evenOdd) so the slat/window detail survives the system tint. The
  full-color foreground (ic_launcher_foreground) is NOT reusable here because
  its cream + green fills are both opaque and would tint to a solid blob.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <!-- lintel / header bar -->
  <path
      android:fillColor="#000000"
      android:pathData="M31,26 h46 a2,2 0 0 1 2,2 v2 a2,2 0 0 1 -2,2 h-46 a2,2 0 0 1 -2,-2 v-2 a2,2 0 0 1 2,-2 z"/>
  <!-- door panel with window + slat cutouts -->
  <path
      android:fillColor="#000000"
      android:fillType="evenOdd"
      android:pathData="M35.5,36 h37 a3.5,3.5 0 0 1 3.5,3.5 v42 a3.5,3.5 0 0 1 -3.5,3.5 h-37 a3.5,3.5 0 0 1 -3.5,-3.5 v-42 a3.5,3.5 0 0 1 3.5,-3.5 z M36,40 h6.5 v5 h-6.5 z M46,40 h6.5 v5 h-6.5 z M56,40 h6.5 v5 h-6.5 z M66,40 h6.5 v5 h-6.5 z M33,48 h42 v1.8 h-42 z M33,58 h42 v1.8 h-42 z M33,68 h42 v1.8 h-42 z M33,78 h42 v1.8 h-42 z"/>
</vector>
