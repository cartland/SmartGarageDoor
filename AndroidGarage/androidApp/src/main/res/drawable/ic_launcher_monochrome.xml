<!--
  Monochrome layer for Android 13+ themed icons. Same garage-door geometry as
  ic_launcher_foreground (the GarageDoorCanvas closed door mapped into 108dp),
  flattened to a single tint-able color. The 4 separate panels leave the slat
  gaps open so the door reads through the system tint; no gradient. The cream +
  green foreground is NOT reusable here - both its fills are opaque and would
  tint to a solid blob.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

  <!-- door panels, clipped inside the frame -->
  <group>
    <clip-path android:pathData="M24.133,24.133 h59.734 v64.867 h-59.734 z"/>
    <path android:fillColor="#000000" android:pathData="M23.667,24.133 h60.667 v14.233 h-60.667 z"/>
    <path android:fillColor="#000000" android:pathData="M23.667,39.767 h60.667 v14.233 h-60.667 z"/>
    <path android:fillColor="#000000" android:pathData="M23.667,55.4 h60.667 v14.233 h-60.667 z"/>
    <path android:fillColor="#000000" android:pathData="M23.667,71.033 h60.667 v14.233 h-60.667 z"/>
    <path android:fillColor="#000000" android:pathData="M51.433,83.867 h5.133 v0.933 h-5.133 z"/>
  </group>

  <!-- U-shaped frame -->
  <path
      android:fillColor="#00000000"
      android:strokeColor="#000000"
      android:strokeWidth="2.8"
      android:strokeLineCap="butt"
      android:pathData="M21.333,86.667 L21.333,25.067 A3.733,3.733 0 0 1 25.067,21.333 L82.933,21.333 A3.733,3.733 0 0 1 86.667,25.067 L86.667,86.667"/>
</vector>
