<!--
  Adaptive-icon foreground: the in-app closed garage door (GarageDoorCanvas.kt,
  doorOffset = 0). The 300-unit Canvas design space is mapped into the 108dp
  adaptive viewport by  v -> v / 6 + 29  (door ~50dp, well inside the 66dp safe
  zone with generous padding so circular / squircle launcher masks don't crop
  the corners). U-shaped frame stroke + 4 panels + handle, with the same
  vertical gradient (#226B43 -> #113521). Panels are clipped inside the frame.
  Keep in sync with GarageDoorCanvas.kt and distribution/playstore/src/icon.svg.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

  <!-- door panels + handle, clipped inside the frame -->
  <group>
    <clip-path android:pathData="M32.667,32.667 h42.666 v46.333 h-42.666 z"/>

    <path android:pathData="M32.333,32.667 h43.333 v10.167 h-43.333 z">
      <aapt:attr name="android:fillColor">
        <gradient android:type="linear" android:startX="54" android:startY="29" android:endX="54" android:endY="79">
          <item android:offset="0.0" android:color="#FF226B43"/>
          <item android:offset="0.3" android:color="#FF226B43"/>
          <item android:offset="1.0" android:color="#FF113521"/>
        </gradient>
      </aapt:attr>
    </path>
    <path android:pathData="M32.333,43.833 h43.333 v10.167 h-43.333 z">
      <aapt:attr name="android:fillColor">
        <gradient android:type="linear" android:startX="54" android:startY="29" android:endX="54" android:endY="79">
          <item android:offset="0.0" android:color="#FF226B43"/>
          <item android:offset="0.3" android:color="#FF226B43"/>
          <item android:offset="1.0" android:color="#FF113521"/>
        </gradient>
      </aapt:attr>
    </path>
    <path android:pathData="M32.333,55.0 h43.333 v10.167 h-43.333 z">
      <aapt:attr name="android:fillColor">
        <gradient android:type="linear" android:startX="54" android:startY="29" android:endX="54" android:endY="79">
          <item android:offset="0.0" android:color="#FF226B43"/>
          <item android:offset="0.3" android:color="#FF226B43"/>
          <item android:offset="1.0" android:color="#FF113521"/>
        </gradient>
      </aapt:attr>
    </path>
    <path android:pathData="M32.333,66.167 h43.333 v10.167 h-43.333 z">
      <aapt:attr name="android:fillColor">
        <gradient android:type="linear" android:startX="54" android:startY="29" android:endX="54" android:endY="79">
          <item android:offset="0.0" android:color="#FF226B43"/>
          <item android:offset="0.3" android:color="#FF226B43"/>
          <item android:offset="1.0" android:color="#FF113521"/>
        </gradient>
      </aapt:attr>
    </path>
    <!-- handle -->
    <path android:fillColor="#FF111111" android:pathData="M52.167,75.333 h3.667 v0.667 h-3.667 z"/>
  </group>

  <!-- U-shaped frame, drawn on top as a stroke -->
  <path
      android:fillColor="#00000000"
      android:strokeWidth="2.0"
      android:strokeLineCap="butt"
      android:pathData="M30.667,77.333 L30.667,33.333 A2.667,2.667 0 0 1 33.333,30.667 L74.667,30.667 A2.667,2.667 0 0 1 77.333,33.333 L77.333,77.333">
    <aapt:attr name="android:strokeColor">
      <gradient android:type="linear" android:startX="54" android:startY="29" android:endX="54" android:endY="79">
        <item android:offset="0.0" android:color="#FF226B43"/>
        <item android:offset="0.3" android:color="#FF226B43"/>
        <item android:offset="1.0" android:color="#FF113521"/>
      </gradient>
    </aapt:attr>
  </path>
</vector>
