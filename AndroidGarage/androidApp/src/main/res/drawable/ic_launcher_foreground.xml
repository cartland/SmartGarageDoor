<!--
  Adaptive-icon foreground: cream garage door (lintel + slatted panel + window
  row) sized within the 66dp safe zone. The window/slat knockouts are painted
  in the brand green (#466730) so they read as openings against the flat green
  background layer. Source of truth for the full-bleed art is
  distribution/playstore/src/icon.svg.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <!-- lintel / header bar -->
  <path
      android:fillColor="#F5F2E8"
      android:pathData="M31,26 h46 a2,2 0 0 1 2,2 v2 a2,2 0 0 1 -2,2 h-46 a2,2 0 0 1 -2,-2 v-2 a2,2 0 0 1 2,-2 z"/>
  <!-- door panel -->
  <path
      android:fillColor="#F5F2E8"
      android:pathData="M35.5,36 h37 a3.5,3.5 0 0 1 3.5,3.5 v42 a3.5,3.5 0 0 1 -3.5,3.5 h-37 a3.5,3.5 0 0 1 -3.5,-3.5 v-42 a3.5,3.5 0 0 1 3.5,-3.5 z"/>
  <!-- window row (knockout to background green) -->
  <path android:fillColor="#466730" android:pathData="M36,40 h6.5 v5 h-6.5 z"/>
  <path android:fillColor="#466730" android:pathData="M46,40 h6.5 v5 h-6.5 z"/>
  <path android:fillColor="#466730" android:pathData="M56,40 h6.5 v5 h-6.5 z"/>
  <path android:fillColor="#466730" android:pathData="M66,40 h6.5 v5 h-6.5 z"/>
  <!-- slat dividers (knockout to background green) -->
  <path android:fillColor="#466730" android:pathData="M33,48 h42 v1.8 h-42 z"/>
  <path android:fillColor="#466730" android:pathData="M33,58 h42 v1.8 h-42 z"/>
  <path android:fillColor="#466730" android:pathData="M33,68 h42 v1.8 h-42 z"/>
  <path android:fillColor="#466730" android:pathData="M33,78 h42 v1.8 h-42 z"/>
</vector>
